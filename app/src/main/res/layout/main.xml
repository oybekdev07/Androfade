<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AndroFade Setup"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:textColor="@android:color/black"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modern Android Remote Control"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="30dp"
        android:textColor="@android:color/darker_gray"/>

    <!-- Server IP Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Server IP Address:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textColor="@android:color/black"/>

    <!-- Server IP Input -->
    <EditText
        android:id="@+id/ipfield"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="192.168.1.100"
        android:padding="12dp"
        android:textSize="16sp"
        android:inputType="text"
        android:layout_marginBottom="20dp"
        android:background="@drawable/edit_text_border"
        android:textColor="@android:color/black"/>

    <!-- Port Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Port Number:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textColor="@android:color/black"/>

    <!-- Port Input -->
    <EditText
        android:id="@+id/portfield"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="5000"
        android:padding="12dp"
        android:textSize="16sp"
        android:inputType="number"
        android:layout_marginBottom="30dp"
        android:background="@drawable/edit_text_border"
        android:textColor="@android:color/black"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:spacing="10dp">

        <Button
            android:id="@+id/buttonstart"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="START"
            android:background="@drawable/button_green"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginEnd="10dp"/>

        <Button
            android:id="@+id/buttonstop"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="STOP"
            android:background="@drawable/button_red"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:enabled="false"/>

    </LinearLayout>

    <!-- Info Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        android:padding="15dp"
        android:background="@drawable/info_box"
        android:gravity="center">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Important:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_red_dark"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Only use this on your own devices. Unauthorized access is illegal."
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"/>

    </LinearLayout>

</LinearLayout>
